# ==============================================================================
# 2. HÀM ĐỌC VÀ LÀM SẠCH DỮ LIỆU TỪ 4 FILE
# ==============================================================================
@st.cache_data
def load_data():
    try:
        df_meta = pd.read_csv("domain_worker_metadata.csv")
        df_desire = pd.read_csv("domain_worker_desires.csv")
        df_expert = pd.read_csv("expert_rated_technological_capability.csv")
        df_task = pd.read_csv("task_statement_with_metadata.csv")
        
        for df in [df_meta, df_desire, df_expert, df_task]:
            df.columns = df.columns.str.strip()
        
        keywords = 'Computer|Software|Developer|Programmer|Database|Network|Security|Data Analyst|Information Systems'
        
        cs_meta = df_meta[df_meta['Occupation (O*NET-SOC Title)'].str.contains(keywords, case=False, na=False)]
        cs_desire = df_desire[df_desire['Occupation (O*NET-SOC Title)'].str.contains(keywords, case=False, na=False)]
        cs_expert = df_expert[df_expert['Occupation (O*NET-SOC Title)'].str.contains(keywords, case=False, na=False)]
        cs_task = df_task[df_task['Occupation (O*NET-SOC Title)'].str.contains(keywords, case=False, na=False)]
        
        return cs_meta, cs_desire, cs_expert, cs_task, None
    except Exception as e:
        return None, None, None, None, str(e)

cs_meta, cs_desire, cs_expert, cs_task, error_msg = load_data()

# ==============================================================================
# 3. SIDEBAR - ĐIỀU HƯỚNG BÁO CÁO
# ==============================================================================
with st.sidebar:
    st.image("https://cdn-icons-png.flaticon.com/512/2040/2040504.png", width=80)
    st.title("Hệ thống Phân tích")
    st.markdown("---")
    
    page = st.radio(
        "MỤC LỤC PHÂN TÍCH:",
        [
            "📊 1. Bức tranh Tổng quan (Thực trạng)", 
            "😫 2. Phân tích Điểm Đau (Nhu cầu)", 
            "🧠 3. Đánh giá Khả thi (Chuyên gia)",
            "🚀 4. KHUYẾN NGHỊ CHIẾN LƯỢC"
        ],
        index=0
    )
    st.markdown("---")
    
    if not error_msg:
        all_occupations = sorted(list(set(cs_meta['Occupation (O*NET-SOC Title)'].unique())))
        selected_jobs = st.multiselect(
            "Phân tích sâu theo Chuyên môn:",
            options=all_occupations,
            default=[],
            placeholder="Mặc định: Toàn ngành IT"
        )
        jobs_to_filter = selected_jobs if selected_jobs else all_occupations
        filtered_meta = cs_meta[cs_meta['Occupation (O*NET-SOC Title)'].isin(jobs_to_filter)]
        filtered_desire = cs_desire[cs_desire['Occupation (O*NET-SOC Title)'].isin(jobs_to_filter)]
        filtered_expert = cs_expert[cs_expert['Occupation (O*NET-SOC Title)'].isin(jobs_to_filter)]
        filtered_task = cs_task[cs_task['Occupation (O*NET-SOC Title)'].isin(jobs_to_filter)]

# ==============================================================================
# 4. KHUNG BÁO CÁO CHÍNH
# ==============================================================================
if error_msg:
    st.error(f"❌ Lỗi dữ liệu: {error_msg}")
else:
    st.title("Báo cáo Phân tích Khả thi Ứng dụng AI Agent")
    st.markdown("**Lĩnh vực:** Khoa học Máy tính (Computer Science) | **Nguồn dữ liệu:** O*NET & Khảo sát WorkBank")
    st.markdown("---")
    
    # --------------------------------------------------------------------------
    # TRANG 1: THỰC TRẠNG (Biểu đồ Radar)
    # --------------------------------------------------------------------------
    if page == "📊 1. Bức tranh Tổng quan (Thực trạng)":
        st.header("Mức độ thâm nhập của AI trong quy trình làm việc IT")
        st.markdown("Phân tích hiện trạng sử dụng các công cụ LLM/AI theo các giai đoạn khác nhau trong vòng đời phát triển phần mềm/hệ thống.")
        
        # Nhóm KPI
        c1, c2, c3 = st.columns(3)
        c1.metric("Tổng Mẫu Phân Tích", f"{len(filtered_meta)} nhân sự")
        
        if 'LLM Use in Work' in filtered_meta.columns:
            ai_heavy_users = len(filtered_meta[filtered_meta['LLM Use in Work'].str.contains('Weekly|Daily', case=False, na=False)])
            rate = (ai_heavy_users / len(filtered_meta)) * 100 if len(filtered_meta) > 0 else 0
            c2.metric("Tỷ lệ phụ thuộc AI Cao (Ngày/Tuần)", f"{rate:.1f}%")
        
        c3.metric("Số lượng ngách nghề nghiệp", filtered_meta['Occupation (O*NET-SOC Title)'].nunique())
        st.markdown("<br>", unsafe_allow_html=True)
        
        # Biểu đồ Radar thể hiện "Dấu chân AI" (AI Footprint)
        col_radar, col_bar = st.columns([1.5, 1])
        
        with col_radar:
            st.subheader("🌐 Ma trận Năng lực: Các lĩnh vực đang bị AI xâm chiếm")
            cols = ['Information Access', 'Edit', 'Idea Generation', 'Communication', 'Analysis', 'Decision', 'Coding', 'System Design', 'Data Processing']
            usage_counts = []
            for col in cols:
                full_col = f'LLM Usage by Type - {col}'
                if full_col in filtered_meta.columns:
                    # Tính phần trăm người dùng Weekly/Daily cho từng task
                    count = filtered_meta[full_col].str.contains('Weekly|Daily', case=False, na=False).sum()
                    pct = (count / len(filtered_meta)) * 100 if len(filtered_meta) > 0 else 0
                    usage_counts.append(pct)
                else:
                    usage_counts.append(0)
            
            fig_radar = go.Figure(data=go.Scatterpolar(
                r=usage_counts + [usage_counts[0]], # Khép kín vòng
                theta=cols + [cols[0]],
                fill='toself',
                fillcolor='rgba(59, 130, 246, 0.4)',
                line=dict(color='#2563EB', width=2),
                name='Tỷ lệ dùng AI'
            ))
            fig_radar.update_layout(
                polar=dict(radialaxis=dict(visible=True, range=[0, max(usage_counts)+10])),
                showlegend=False, height=450, margin=dict(t=30, b=30, l=30, r=30)
            )
            st.plotly_chart(fig_radar, use_container_width=True)
            
        with col_bar:
            st.subheader("💡 Nhận định Chuyên môn")
            st.info("""
            **Từ đồ thị Radar, có thể thấy:**
            1. **Điểm nóng (Đỉnh chóp):** Nhân sự IT đang phụ thuộc mạnh nhất vào AI cho việc Truy xuất thông tin (Information Access), Phân tích (Analysis) và Viết Code.
            2. **Điểm lạnh (Lõm vào):** Các công việc đòi hỏi tư duy trừu tượng cao như Thiết kế Hệ thống (System Design) hay Ra quyết định (Decision) tỷ lệ dùng AI vẫn còn hạn chế.
            
            👉 *Tiềm năng cốt lõi của AI Agent hiện tại là đóng vai trò 'Trợ lý thực thi' thay vì 'Kiến trúc sư trưởng'.*
            """)

    # --------------------------------------------------------------------------
    # TRANG 2: NHU CẦU (Phân tích nguyên nhân)
    # --------------------------------------------------------------------------
    elif page == "😫 2. Phân tích Điểm Đau (Nhu cầu)":
        st.header("Tại sao nhân sự IT muốn tự động hóa công việc?")
        
        if not filtered_desire.empty:
            tab1, tab2 = st.tabs(["🌳 Treemap: Tác vụ gây nhàm chán", "📊 Lý do gốc rễ (Root Cause)"])
            
            with tab1:
                st.markdown("Biểu đồ Treemap thể hiện các tác vụ đang vắt kiệt sức nhân sự. **Ô càng to & màu càng đỏ** = Tác vụ đó càng bị ghét và khao khát được AI làm thay.")
                desire_agg = filtered_desire.groupby('Task', as_index=False).agg({
                    'Automation Desire Rating': 'mean',
                    'Enjoyment Rating': 'mean'
                }).sort_values('Automation Desire Rating', ascending=False).head(15)
                
                # Biểu đồ Treemap
                fig_tree = px.treemap(
                    desire_agg, 
                    path=[px.Constant("Tác vụ cần Tự động hóa"), 'Task'], 
                    values='Automation Desire Rating',
                    color='Enjoyment Rating', 
                    color_continuous_scale='RdYlGn', # Đỏ là chán, Xanh là thích
                    hover_data=['Automation Desire Rating']
                )
                fig_tree.update_layout(height=500, margin=dict(t=20, l=0, r=0, b=0))
                st.plotly_chart(fig_tree, use_container_width=True)
                
            with tab2:
                st.subheader("Phân tích Lý do thúc đẩy nhu cầu tự động hóa")
                reasons = [c for c in filtered_desire.columns if 'Reasons for Automation Desire' in c]
                reason_counts = []
                reason_names = []
                for r in reasons:
                    name = r.split(' - ')[-1]
                    count = filtered_desire[r].sum() if r in filtered_desire.columns else 0
                    reason_names.append(name)
                    reason_counts.append(count)
                
                df_reasons = pd.DataFrame({'Lý do': reason_names, 'Số lượt chọn': reason_counts}).sort_values('Số lượt chọn', ascending=True)
                
                fig_reason = px.bar(df_reasons, x='Số lượt chọn', y='Lý do', orientation='h', text_auto=True,
                                    color='Số lượt chọn', color_continuous_scale='Sunset')
                fig_reason.update_layout(height=400, showlegend=False, xaxis_title="Mức độ phổ biến", yaxis_title="")
                st.plotly_chart(fig_reason, use_container_width=True)

    # --------------------------------------------------------------------------
    # TRANG 3: CHUYÊN GIA (Ma trận Đánh giá)
    # --------------------------------------------------------------------------
    elif page == "🧠 3. Đánh giá Khả thi (Chuyên gia)":
        st.header("Kiểm chứng từ Chuyên gia Công nghệ")
        st.markdown("Đối chiếu nhu cầu của nhân sự với năng lực thực tế của AI hiện tại để tránh 'ảo tưởng sức mạnh'.")
        
        if not filtered_expert.empty:
            expert_stats = filtered_expert.groupby('Task', as_index=False).agg({
                'Automation Capacity Rating': 'mean', 
                'Human Agency Scale Rating': 'mean'
            })
            
            col1, col2 = st.columns([2, 1])
            with col1:
                # Biểu đồ Scatter (Quadrant)
                fig_scatter = px.scatter(
                    expert_stats, x='Automation Capacity Rating', y='Human Agency Scale Rating',
                    hover_name='Task', color='Automation Capacity Rating', 
                    color_continuous_scale='Viridis', size_max=15, size=[10]*len(expert_stats)
                )
                
                # Vẽ trục chia 4 góc
                med_x = 3.0
                med_y = 2.5
                fig_scatter.add_shape(type="line", x0=med_x, y0=0, x1=med_x, y1=5, line=dict(color="red", dash="dash"))
                fig_scatter.add_shape(type="line", x0=0, y0=med_y, x1=5, y1=med_y, line=dict(color="red", dash="dash"))
                
                # Ghi chú cho 4 góc
                fig_scatter.add_annotation(x=4.5, y=1, text="VÙNG VÀNG<br>(Năng lực Cao - Ít Cần Người)", showarrow=False, font=dict(color="green", size=11, weight="bold"))
                fig_scatter.add_annotation(x=4.5, y=4, text="VÙNG PHỐI HỢP<br>(Giỏi nhưng cần Giám sát)", showarrow=False, font=dict(color="orange", size=11))
                
                fig_scatter.update_layout(
                    height=500, xaxis_title="Khả năng Tự động hóa của AI", yaxis_title="Mức độ cần Con người can thiệp"
                )
                st.plotly_chart(fig_scatter, use_container_width=True)
                
            with col2:
                st.info("""
                **Cách đọc Ma trận Phân vị:**
                - **Góc dưới bên phải (Vùng Vàng):** Đây là các task AI làm rất xuất sắc và không cần con người nhúng tay nhiều. Đẩy mạnh tự động hóa ngay!
                - **Góc trên bên phải:** AI làm giỏi, nhưng tính chất công việc quá rủi ro (bảo mật, đạo đức), nên vẫn cần mô hình *Human-in-the-loop*.
                """)
                high_cap = expert_stats[expert_stats['Automation Capacity Rating'] >= 3.5]
                st.metric("Tác vụ đủ chuẩn kỹ thuật (Điểm > 3.5)", f"{len(high_cap)} tác vụ")

    # --------------------------------------------------------------------------
    # TRANG 4: CHIẾN LƯỢC TOÀN DIỆN (ĂN ĐIỂM)
    # --------------------------------------------------------------------------
    elif page == "🚀 4. KHUYẾN NGHỊ CHIẾN LƯỢC":
        st.header("Kết luận: Ma trận Ưu tiên Triển khai AI Agent")
        st.markdown("""
        Bản báo cáo này kết hợp Mức độ quan trọng của công việc (O*NET) + Năng lực của AI (Chuyên gia) + Mức lương chi trả. 
        **Mục tiêu:** Chỉ ra chính xác Doanh nghiệp nên ném tiền vào ứng dụng AI Agent cho việc gì để tối ưu ROI (Tỷ suất hoàn vốn) cao nhất.
        """)
        
        if not filtered_task.empty and not filtered_expert.empty:
            if 'Task' in filtered_expert.columns and 'Task' in filtered_task.columns:
                
                expert_agg = filtered_expert.groupby('Task', as_index=False)['Automation Capacity Rating'].mean()
                task_agg = filtered_task.groupby('Task', as_index=False).agg({
                    'Importance': 'mean',
                    'Occupation Mean Annual Wage': 'mean'
                })
                
                merged_df = pd.merge(expert_agg, task_agg, on='Task', how='inner')
                
                if not merged_df.empty:
                    # Fix lỗi NaN cho mức lương (Đảm bảo đồ thị Bubble không sập)
                    mean_wage = merged_df['Occupation Mean Annual Wage'].mean()
                    fill_value = mean_wage if not pd.isna(mean_wage) else 100000 
                    merged_df['Occupation Mean Annual Wage'] = merged_df['Occupation Mean Annual Wage'].fillna(fill_value)
                    
                    st.subheader("💥 Bản đồ Bong bóng: Định vị Giá trị Tự động hóa")
                    st.markdown("*Bong bóng càng to = Mức lương chi trả cho công việc đó càng cao (Tiết kiệm được nhiều tiền nhất).*")
                    
                    fig_matrix = px.scatter(
                        merged_df, 
                        x='Importance', 
                        y='Automation Capacity Rating',
                        size='Occupation Mean Annual Wage',
                        color='Automation Capacity Rating',
                        hover_name='Task',
                        color_continuous_scale='Turbo',
                        size_max=30, # Phóng to bong bóng nhìn cho rõ
                        labels={
                            'Importance': 'Mức độ Quan trọng Lõi (Core Task)',
                            'Automation Capacity Rating': 'Năng lực xử lý của AI',
                        }
                    )
                    
                    med_imp = merged_df['Importance'].median()
                    med_cap = merged_df['Automation Capacity Rating'].median()
                    fig_matrix.add_hline(y=med_cap, line_dash="dot", line_color="gray")
                    fig_matrix.add_vline(x=med_imp, line_dash="dot", line_color="gray")
                    
                    fig_matrix.add_annotation(
                        x=merged_df['Importance'].max(), y=merged_df['Automation Capacity Rating'].max(),
                        text="⭐ MỎ VÀNG CHIẾN LƯỢC<br>(Lõi + Dễ AI hóa)", 
                        showarrow=False, font=dict(color="green", size=14, weight="bold"),
                        bgcolor="rgba(255,255,255,0.8)", bordercolor="green"
                    )
                    
                    fig_matrix.update_layout(height=600, plot_bgcolor='rgba(248, 250, 252, 1)')
                    st.plotly_chart(fig_matrix, use_container_width=True)
                    
                    st.markdown("---")
                    st.subheader("🔥 DANH SÁCH HÀNH ĐỘNG (ACTION ITEMS)")
                    st.markdown("Top các tác vụ cần ưu tiên phát triển AI Agent ngay lập tức (Sắp xếp theo Khả năng AI):")
                    
                    top_targets = merged_df[(merged_df['Importance'] >= med_imp) & (merged_df['Automation Capacity Rating'] >= med_cap)]
                    
                    # Trình bày bảng dữ liệu đẹp hơn
                    st.dataframe(
                        top_targets.sort_values(by='Automation Capacity Rating', ascending=False)[['Task', 'Automation Capacity Rating', 'Importance', 'Occupation Mean Annual Wage']].head(10).style.format({"Occupation Mean Annual Wage": "${:,.0f}", "Automation Capacity Rating": "{:.1f}", "Importance": "{:.1f}"}),
                        use_container_width=True
                    )
                else:
                    st.warning("⚠️ Chưa tìm thấy sự trùng khớp tên tác vụ.")
            else:
                st.error("⚠️ Dữ liệu bị thiếu cột 'Task'.")
